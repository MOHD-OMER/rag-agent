# ============================================================
# RAG Agent — Environment Configuration
# ============================================================

# --- LLM Provider (choose one) ---
# Option 1: Groq (recommended for speed, free tier available)
# Option 1: Groq (recommended for speed)
GROQ_API_KEY=your-groq-api-key-here
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.1-8b-instant

# Option 2: Ollama (local)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Search Tool ---
TAVILY_API_KEY=your-tavily-api-key-here

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Storage & Persistence ---
CHROMA_PERSIST_DIR=./backend/chroma_db
AGENT_CHECKPOINT_DB=./backend/agent_memory.db
CHROMA_COLLECTION_NAME=rag_documents

# --- Retrieval Config ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=6
BM25_WEIGHT=0.4
DENSE_WEIGHT=0.6

# --- Memory & API ---
MEMORY_WINDOW_SIZE=10
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:8501

# --- Logging ---
LOG_LEVEL=INFO
